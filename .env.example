# Clave de Gemini — consíguela en https://aistudio.google.com/apikey
# Copia este archivo a ".env" y rellena los valores. ".env" está en .gitignore — nunca commitees tu clave.
GEMINI_API_KEY=

# Opcional: modelo a usar para comprensión de vídeo (por defecto gemini-2.5-flash).
GEMINI_MODEL=gemini-2.5-flash
